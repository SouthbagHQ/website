---
import type { IdentityUser } from "../lib/identity";
import { IDENTITY_DASHBOARD_URL, IDENTITY_LOGIN_URL } from "../lib/identity";

interface Props {
  currentPage?: string;
  user?: IdentityUser | null;
}
const { currentPage = "", user = null } = Astro.props;
const displayName = user?.email;

const navLinks = [
  { label: "Financial", href: "/financial", key: "financial" },
  { label: "Digital", href: "/digital", key: "digital" },
  { label: "Business", href: "/business", key: "business" },
];
---

<header class="sb-nav">
  <nav class="sb-nav-bar">
    <div class="sb-nav-inner">
      <a href="/" class="sb-wordmark">
        <span class="sb-wordmark-text">SOUTHBAG</span>
      </a>

      <ul class="sb-nav-links">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "sb-nav-link",
                  { "is-active": currentPage === link.key },
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="sb-nav-right">
        {
          user ? (
            <div class="sb-auth-user">
              <span class="sb-auth-name">{displayName}</span>
              <a href={IDENTITY_DASHBOARD_URL} class="sb-btn sb-btn-primary">
                Dashboard
              </a>
            </div>
          ) : (
            <div class="sb-auth-guest">
              <a href={IDENTITY_LOGIN_URL} class="sb-btn sb-btn-ghost">
                Sign In
              </a>
              <a href={IDENTITY_LOGIN_URL} class="sb-btn sb-btn-primary">
                Get Started
              </a>
            </div>
          )
        }
      </div>

      <button
        class="sb-mobile-menu-btn"
        id="menuToggle"
        aria-label="Toggle navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="sb-mobile-menu" id="mobileMenu">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "sb-mobile-link",
              { "is-active": currentPage === link.key },
            ]}
          >
            {link.label}
          </a>
        ))
      }
      {
        user ? (
          <>
            <span class="sb-mobile-link sb-mobile-auth-name">
              {displayName}
            </span>
            <a
              href={IDENTITY_DASHBOARD_URL}
              class="sb-mobile-link sb-mobile-start"
            >
              Dashboard
            </a>
          </>
        ) : (
          <>
            <a
              href={IDENTITY_LOGIN_URL}
              class="sb-mobile-link sb-mobile-signin"
            >
              Sign In
            </a>
            <a href={IDENTITY_LOGIN_URL} class="sb-mobile-link sb-mobile-start">
              Get Started
            </a>
          </>
        )
      }
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("menuToggle");
  const menu = document.getElementById("mobileMenu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("is-open");
    btn.classList.toggle("is-open");
  });
</script>

<style>
  .sb-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--sb-surface);
    border-bottom: 1px solid var(--sb-border);
  }

  /* ── Nav bar ── */
  .sb-nav-bar {
    background: var(--sb-surface);
  }

  .sb-nav-inner {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    padding: 0 24px;
    max-width: 1280px;
    margin: 0 auto;
    gap: 32px;
  }

  /* ── Wordmark ── */
  .sb-wordmark {
    display: block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .sb-wordmark-text {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.25em;
    color: var(--sb-heading);
    line-height: 1;
  }

  /* ── Nav links ── */
  .sb-nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .sb-nav-link {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sb-text-dim);
    padding: 0 16px;
    height: var(--nav-height);
    line-height: var(--nav-height);
    border-right: 1px solid var(--sb-border);
    text-decoration: none;
  }

  .sb-nav-link:first-child {
    border-left: 1px solid var(--sb-border);
  }

  .sb-nav-link:hover {
    color: var(--sb-text);
    background: rgba(255, 255, 255, 0.02);
  }

  .sb-nav-link.is-active {
    color: var(--sb-heading);
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--sb-border-active);
  }

  /* ── Right side ── */
  .sb-nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
  }

  .sb-auth-guest,
  .sb-auth-user {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .sb-auth-name {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sb-text-dim);
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sb-nav-right .sb-btn {
    font-size: 10px;
    padding: 6px 14px;
  }

  /* ── Mobile button ── */
  .sb-mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .sb-mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--sb-text-dim);
  }

  .sb-mobile-menu-btn.is-open span:nth-child(2) {
    opacity: 0;
  }

  /* ── Mobile menu ── */
  .sb-mobile-menu {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--sb-border);
    background: var(--sb-surface);
  }

  .sb-mobile-menu.is-open {
    display: flex;
  }

  .sb-mobile-link {
    padding: 14px 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sb-text-dim);
    border-bottom: 1px solid var(--sb-border);
    text-decoration: none;
  }

  .sb-mobile-link:hover,
  .sb-mobile-link.is-active {
    color: var(--sb-heading);
    background: rgba(255, 255, 255, 0.02);
  }

  .sb-mobile-auth-name {
    color: var(--sb-text);
    cursor: default;
  }

  .sb-mobile-signin {
    color: var(--sb-accent-text);
  }

  .sb-mobile-start {
    color: #c0d4f0;
    background: var(--sb-accent-bg);
    border-color: var(--sb-accent-border);
  }

  @media (max-width: 768px) {
    .sb-nav-links,
    .sb-nav-right {
      display: none;
    }

    .sb-mobile-menu-btn {
      display: flex;
    }

    .sb-nav-inner {
      padding: 0 16px;
    }
  }
</style>
