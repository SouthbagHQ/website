---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'Southbag',
  description = 'An ecosystem of services you do not fully control.',
  currentPage = '',
} = Astro.props;

const fullTitle = title === 'Southbag'
  ? 'Southbag — Institutional Services'
  : `${title} — Southbag`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav currentPage={currentPage} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
